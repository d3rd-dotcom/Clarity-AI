# ─────────────────────────────────────────────────────────────
# CLARITY-ELIGIBILITY FRONTEND — Environment Variables
# Copy this to .env.local and fill in your values.
# VITE_ prefix = safe to expose in the browser bundle.
# ─────────────────────────────────────────────────────────────

# Backend API URL
# DEV:  Leave empty — Vite proxy forwards /api/* to localhost:3001
# PROD (same server): Leave empty — calls go to same origin
# PROD (separate deploy e.g. Railway backend + Vercel frontend):
#   Set this to your Railway/Render backend URL
VITE_API_URL=
