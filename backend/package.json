{
  "name": "clarity-eligibility-backend",
  "version": "1.0.0",
  "description": "Backend RAG pipeline for Clarity-Eligibility AI — UK Benefits Navigator",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "esbuild server.ts seed.ts --bundle --platform=node --format=cjs --packages=external --outdir=dist",
    "start": "node dist/server.cjs",
    "seed": "tsx seed.ts",
    "lint": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cohere-ai": "^7.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
