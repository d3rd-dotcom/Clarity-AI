# ============================================================
# CLARITY-ELIGIBILITY AI — BACKEND ENV VARIABLES
# Copy this to .env and fill in your real values
# NEVER commit .env to git
# ============================================================

# --- Supabase ---
# Get from: supabase.com → your project → Settings → API
# Use the SERVICE ROLE key (not anon key) — server-side only
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here 

# --- Cohere ---
# Get from: dashboard.cohere.com → API Keys
# Free trial key works — no credit card needed
COHERE_API_KEY=your-cohere-api-key-here

# --- Cerebras (Primary LLM) ---
# Get from: cloud.cerebras.ai → API Keys
# Free tier: 1M tokens/day, no credit card
CEREBRAS_API_KEY=your-cerebras-api-key-here

# --- Groq (Fallback LLM) ---
# Get from: console.groq.com → API Keys
# Free tier available
GROQ_API_KEY=your-groq-api-key-here

# --- Server Config ---
PORT=3001

# --- Indexing Security ---
# Random secret to protect the /api/index endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INDEX_SECRET=your-random-secret-here

# --- Environment ---
NODE_ENV=development